{
    "version": 2,
    "public": true,
    "cleanUrls": true,
    "trailingSlash": false,
    "routes": [
      {
        "src": "/go",
        "dest": "/mobile.html"
      },
      {
        "handle": "filesystem"
      },
      {
        "src": "/(.*)",
        "dest": "/index.html"
      }
    ]
  }
